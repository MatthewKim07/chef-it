// Copy this file to Secrets.xcconfig and fill in your values.
// Secrets.xcconfig is gitignored — never commit it.
//
// Get credentials at: https://developer.edamam.com

EDAMAM_APP_ID = your_app_id_here
EDAMAM_APP_KEY = your_app_key_here
// Note: use $() to escape // in URLs, otherwise xcconfig treats it as a comment.
AUTH_BASE_URL = http:$()/127.0.0.1:3000
